NODE_ENV=production
NEXT_PUBLIC_API_URL=

SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_URL=https://wynwjussvlszzeuagccp.supabase.co/storage/v1

JWT_SECRET=

ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Usada por /api/audio/transcrever para transcrever áudios recebidos via
# WhatsApp com o Whisper da OpenAI (chamado pelo Fluxo 02 do n8n).
OPENAI_API_KEY=

N8N_GERAR_CONTRATO_URL=
N8N_SINCRONIZAR_PROMPTS_URL=

# Segredo compartilhado com o n8n para os endpoints de cron
# (GET /api/followup-processar e GET /api/mensagens/agendadas),
# enviado no header x-cron-secret.
CRON_SECRET=

# Segredo compartilhado com o n8n para as rotas internas em /api/internal/*
# (ex.: POST /api/internal/transcrever), enviado no header x-internal-secret.
# Essas rotas não passam pela checagem de JWT do middleware.
INTERNAL_API_SECRET=

# Envio do código de recuperação de senha (login/recuperar-senha)
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Não usada pelo código atual (auth é via JWT/jose, não NextAuth).
# Mantida aqui só porque foi pedida explicitamente.
NEXTAUTH_URL=
